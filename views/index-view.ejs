<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CatatDigital — Warungmu Lebih Rapi, Rezekinya Lebih Jelas</title>

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/styles/index-css.css" />
  </head>

  <body class="border border-5 border-danger">
    <!-- NAVBAR -->
    <nav class="cd-nav">
      <div class="container">
        <div class="d-flex align-items-center justify-content-between">
          <!-- Logo -->
          <div class="d-flex align-items-center gap-2">
            <div class="brand-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"
                  stroke="#fff"
                  stroke-width="2.2"
                  stroke-linecap="round"
                />
                <rect
                  x="9"
                  y="3"
                  width="6"
                  height="4"
                  rx="1"
                  stroke="#fff"
                  stroke-width="2.2"
                />
                <path
                  d="M9 12h6M9 16h4"
                  stroke="#fff"
                  stroke-width="2.2"
                  stroke-linecap="round"
                />
              </svg>
            </div>
            <span class="brand-text">Catat<span>Digital</span></span>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero-section">
      <div class="container">
        <div class="row align-items-center g-5">
          <!-- LEFT copy -->
          <div class="col-lg-6 text-center text-lg-start">
            <h1 class="display-hero mb-4 fade-up d1">
              Foto Buku Kas<br />
              <span class="squig-wrap">
                <span class="em">Usahamu,</span>
                <svg
                  height="8"
                  viewBox="0 0 200 8"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  style="height: 8px"
                >
                  <path
                    d="M0 6 Q25 1 50 5 Q75 9 100 5 Q125 1 150 5 Q175 9 200 5"
                    stroke="url(#sq)"
                    stroke-width="2.5"
                    stroke-linecap="round"
                  />
                  <defs>
                    <linearGradient
                      id="sq"
                      x1="0"
                      x2="200"
                      y1="0"
                      y2="0"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop stop-color="#34D399" />
                      <stop offset="1" stop-color="#A78BFA" />
                    </linearGradient>
                  </defs>
                </svg> </span
              ><br />
              <span class="dim" style="font-size: clamp(1.7rem, 3.8vw, 3rem)"
                >Biar AI yang Rapiinnya</span
              >
            </h1>

            <p
              style="
                color: var(--text-secondary);
                font-size: 0.97rem;
                line-height: 1.75;
                max-width: 500px;
                margin: 0 auto 28px;
              "
              class="fade-up d2"
            >
              Capek hitung manual di buku kas dan sering salah? Cukup
              <strong style="color: #fff"
                >foto buku kas atau catatan usahamu</strong
              >, dan CatatDigital akan otomatis rekap, audit, dan ekspor ke
              <strong style="color: var(--em-400)">Excel</strong> — dalam
              hitungan detik.
            </p>
          </div>

          <!-- RIGHT mockup -->
          <div class="col-lg-6">
            <div class="glass mockup-card" style="padding: 16px">
              <!-- Top bar -->
              <div class="mockup-top-bar">
                <div class="dot-red"></div>
                <div class="dot-amber"></div>
                <div class="dot-green"></div>
                <span class="mockup-filename"
                  >nota_warung_budi_27jan.jpg — AI Sedang Menganalisa...</span
                >
              </div>

              <!-- Paper note -->
              <div class="paper-note">
                <div class="paper-lines"></div>
                <div class="paper-content">
                  <div class="paper-row">
                    <div class="paper-line" style="width: 90px"></div>
                    <div
                      class="paper-line"
                      style="width: 60px; opacity: 0.7"
                    ></div>
                  </div>
                  <div class="paper-divider"></div>
                  <div class="paper-row">
                    <div class="paper-line" style="width: 108px"></div>
                    <div class="paper-line em" style="width: 50px"></div>
                  </div>
                  <div class="paper-row">
                    <div
                      class="paper-line"
                      style="width: 80px; opacity: 0.8"
                    ></div>
                    <div class="paper-line em" style="width: 44px"></div>
                  </div>
                  <div class="paper-row">
                    <div class="paper-line" style="width: 120px"></div>
                    <div class="paper-line em" style="width: 56px"></div>
                  </div>
                  <div class="paper-row">
                    <div
                      class="paper-line"
                      style="width: 64px; opacity: 0.6"
                    ></div>
                    <div
                      class="paper-line"
                      style="width: 38px; opacity: 0.5"
                    ></div>
                  </div>
                  <div class="paper-divider"></div>
                  <div class="paper-error-row">
                    <div
                      class="paper-line"
                      style="width: 76px; background: rgba(255, 255, 255, 0.35)"
                    ></div>
                    <div style="display: flex; align-items: center; gap: 8px">
                      <div class="paper-line red" style="width: 54px"></div>
                      <svg
                        width="13"
                        height="13"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="#f87171"
                        stroke-width="2.5"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
                        />
                      </svg>
                    </div>
                  </div>
                </div>
                <div class="scan-line-overlay"></div>
                <div class="ai-processing-badge">
                  <span
                    style="
                      width: 6px;
                      height: 6px;
                      border-radius: 50%;
                      background: var(--vi-400);
                      animation: dotPulse 1.4s ease-in-out infinite;
                      display: block;
                    "
                  ></span>
                  Gemini AI
                </div>
              </div>

              <!-- Result -->
              <div class="mockup-result">
                <div class="result-header">
                  <div class="result-check">
                    <svg
                      width="11"
                      height="11"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="#fff"
                      stroke-width="3"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </div>
                  <span
                    style="
                      font-size: 0.73rem;
                      font-weight: 700;
                      color: var(--em-400);
                    "
                    >AI Selesai Mengaudit — 1 Kesalahan Ditemukan &
                    Diperbaiki</span
                  >
                </div>
                <div class="result-grid">
                  <div class="result-cell">
                    <div class="result-num" style="color: var(--em-400)">
                      12
                    </div>
                    <div class="result-lbl">Item Tercatat</div>
                  </div>
                  <div class="result-cell">
                    <div class="result-num" style="color: var(--vi-400)">1</div>
                    <div class="result-lbl">Error Dikoreksi</div>
                  </div>
                  <div class="result-cell">
                    <div class="result-num" style="color: var(--em-400)">✓</div>
                    <div class="result-lbl">Siap Ekspor</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!--  STATS STRIP  -->
    <div class="stats-strip">
      <div class="container">
        <div class="row g-4 text-center">
          <div class="col-6 col-md-3">
            <div class="stat-num">98%</div>
            <div class="stat-lbl">Akurasi Baca Tulisan Tangan</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-num"><span class="text-em">&lt;</span>5 dtk</div>
            <div class="stat-lbl">Waktu Proses per Foto</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-num">0 Rp</div>
            <div class="stat-lbl">Untuk Fitur Uji Coba</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-num"><span class="text-vi">∞</span></div>
            <div class="stat-lbl">Lembar Nota Bisa Diproses</div>
          </div>
        </div>
      </div>
    </div>

    <!-- UPLOAD SECTION -->
    <section id="upload" class="upload-section">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-8 col-xl-7">
            <!-- Section header -->
            <div class="text-center mb-5">
              <h2 class="section-title mb-3">
                Upload Foto Buku Kas atau<br /><span class="text-em"
                  >Langsung Foto</span
                >
                di Sini
              </h2>
              <p
                style="
                  color: var(--text-muted);
                  font-size: 0.9rem;
                  max-width: 440px;
                  margin: 0 auto;
                "
              >
                Tidak perlu aplikasi tambahan. Pakai kamera HP-mu langsung, atau
                pilih foto dari galeri.
              </p>
            </div>

            <!-- Card -->
            <div class="glass upload-card">
              <form
                id="upload-form"
                action="/api/v1/audit-catatan"
                method="POST"
                enctype="multipart/form-data"
              >
                <!-- Dropzone -->
                <div
                  class="dropzone"
                  id="dropzone"
                  onclick="document.getElementById('file-input').click()"
                  ondragover="
                    event.preventDefault();
                    this.classList.add('drag-over');
                  "
                  ondragleave="this.classList.remove('drag-over')"
                  ondrop="handleDrop(event)"
                >
                  <div class="dz-ring-1"></div>
                  <div class="dz-ring-2"></div>

                  <input
                    type="file"
                    id="file-input"
                    name="financialRecordFile"
                    accept="image/*"
                    class="d-none"
                    onchange="handleFileSelect(event)"
                  />

                  <div class="dz-icon-wrap">
                    <svg width="28" height="28" fill="none" viewBox="0 0 24 24">
                      <path
                        d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
                        stroke="url(#upG)"
                        stroke-width="1.9"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <defs>
                        <linearGradient
                          id="upG"
                          x1="0"
                          y1="0"
                          x2="24"
                          y2="24"
                          gradientUnits="userSpaceOnUse"
                        >
                          <stop stop-color="#34D399" />
                          <stop offset="1" stop-color="#A78BFA" />
                        </linearGradient>
                      </defs>
                    </svg>
                  </div>

                  <p class="dz-title">Seret foto buku kas ke sini</p>
                  <p class="dz-sub">atau tekan untuk pilih file dari galeri</p>

                  <div class="format-badge">
                    <span>JPG</span><span>PNG</span><span>WEBP</span
                    ><span>HEIC</span>
                  </div>
                </div>

                <!-- Preview -->
                <div class="preview-area" id="preview-area">
                  <div class="preview-inner">
                    <img id="preview-img" src="" alt="Preview nota" />
                    <button
                      type="button"
                      class="preview-close"
                      onclick="clearPreview()"
                    >
                      × Ganti Foto
                    </button>
                    <div class="preview-ready">
                      <span
                        style="
                          width: 7px;
                          height: 7px;
                          border-radius: 50%;
                          background: var(--em-400);
                          animation: dotPulse 1.6s ease-in-out infinite;
                          display: block;
                        "
                      ></span>
                      Foto siap diproses
                    </div>
                  </div>
                </div>

                <!-- OR divider -->
                <div class="or-divider">
                  <span>Atau pakai kamera langsung</span>
                </div>

                <!-- Camera buttons -->
                <div class="cam-btn-wrap">
                  <label for="camera-input" class="cam-label vi-cam">
                    <svg
                      width="19"
                      height="19"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"
                      />
                    </svg>
                    📷 Buka Kamera HP

                    <!-- SINKRONISASI: type diubah ke "file", name diubah menjadi "financialRecordFile" -->
                    <input
                      type="file"
                      id="camera-input"
                      name="financialRecordFile"
                      accept="image/*"
                      capture="environment"
                      class="d-none"
                      onchange="handleFileSelect(event)"
                    />
                  </label>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit">
                  <svg
                    width="20"
                    height="20"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"
                    />
                  </svg>
                  Analisa dengan AI Gemini Sekarang!
                </button>

                <p class="trust-note">
                  🔒 Foto kamu diproses aman & tidak disimpan permanen. Privasi
                  terjamin.
                </p>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LOADING DISPLAY -->
    <div id="loading-overlay">
      <div class="spinner-wrap">
        <div class="spinner-ring ring-outer"></div>
        <div class="spinner-ring ring-mid"></div>
        <div class="spinner-ring ring-inner"></div>
        <div class="spinner-center">
          <svg width="26" height="26" fill="none" viewBox="0 0 24 24">
            <path
              d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"
              stroke="url(#loadG)"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <defs>
              <linearGradient
                id="loadG"
                x1="0"
                y1="0"
                x2="24"
                y2="24"
                gradientUnits="userSpaceOnUse"
              >
                <stop stop-color="#34D399" />
                <stop offset="1" stop-color="#A78BFA" />
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>

      <h2 class="load-title" id="load-title">Membaca tulisan di nota...</h2>
      <p class="load-sub">
        AI Gemini sedang menganalisa setiap baris transaksi dengan teliti
      </p>

      <div class="progress-track">
        <div class="progress-fill" id="prog-fill"></div>
      </div>

      <div class="step-indicators">
        <div class="step-ind">
          <div class="step-circle done" id="si-1">
            <svg
              width="14"
              height="14"
              fill="none"
              viewBox="0 0 24 24"
              stroke="var(--em-400)"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"
              />
            </svg>
          </div>
          <span class="step-lbl">Scan OCR</span>
        </div>
        <div class="step-connector"></div>
        <div class="step-ind">
          <div class="step-circle active" id="si-2">
            <svg
              width="14"
              height="14"
              fill="none"
              viewBox="0 0 24 24"
              stroke="var(--vi-400)"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"
              />
            </svg>
          </div>
          <span class="step-lbl">AI Audit</span>
        </div>
        <div class="step-connector"></div>
        <div class="step-ind">
          <div class="step-circle" id="si-3">
            <svg
              width="14"
              height="14"
              fill="none"
              viewBox="0 0 24 24"
              stroke="var(--text-muted)"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
              />
            </svg>
          </div>
          <span class="step-lbl">Ekspor Excel</span>
        </div>
      </div>
    </div>

    <!-- RESULT SUCCESS MODAL -->
    <div id="result-modal" class="modal-overlay">
      <div class="modal-card glass">
        <div class="modal-icon success">
          <svg
            width="32"
            height="32"
            fill="none"
            viewBox="0 0 24 24"
            stroke="#34D399"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M5 13l4 4L19 7"
            />
          </svg>
        </div>
        <h3 class="modal-title">Audit Selesai Ditinjau!</h3>
        <p class="modal-sub">
          AI Gemini berhasil memproses berkas finansial Anda ke Excel.
        </p>

        <div class="audit-summary-box">
          <div class="summary-item">
            <span class="summary-label">Total Terhitung</span>
            <span class="summary-val" id="res-total">Rp 0</span>
          </div>
          <div class="summary-item">
            <span class="summary-label">Selisih Temuan</span>
            <span class="summary-val" id="res-discrepancy">Rp 0</span>
          </div>
        </div>

        <p class="res-notes" id="res-notes"></p>

        <div class="modal-actions">
          <!-- Link Download Excel/Sheets -->
          <a
            href="#"
            id="download-link"
            class="btn-modal-primary"
            target="_blank"
          >
            📥 Unduh Laporan Excel
          </a>
          <button
            type="button"
            class="btn-modal-secondary"
            onclick="closeResultModal()"
          >
            Tutup
          </button>
        </div>
      </div>
    </div>

    <!-- ERROR MODAL -->
    <div id="error-modal" class="modal-overlay">
      <div class="modal-card glass">
        <div class="modal-icon error">
          <svg
            width="32"
            height="32"
            fill="none"
            viewBox="0 0 24 24"
            stroke="#EF4444"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
        </div>
        <h3 class="modal-title">Gagal Memproses Audit</h3>
        <p class="modal-sub" id="error-message">
          Terjadi kesalahan saat membaca dokumen atau jaringan terputus.
        </p>

        <div class="modal-actions">
          <button
            type="button"
            class="btn-modal-danger"
            onclick="closeErrorModal()"
          >
            Coba Lagi
          </button>
        </div>
      </div>
    </div>

    <!-- FEATURES -->
    <section id="features" class="features-section">
      <div class="container">
        <!-- Header -->
        <div class="text-center mb-5">
          <span class="badge-pill vi mb-3">3 Kekuatan Utama</span>
          <h2 class="section-title mb-3">
            Dari Buku Tulis<br /><span class="grad-text"
              >ke Dashboard Digital</span
            >
          </h2>
          <p
            style="
              color: var(--text-muted);
              font-size: 0.9rem;
              max-width: 440px;
              margin: 0 auto;
            "
          >
            Tidak perlu belajar akuntansi. Tidak perlu software mahal. Cukup
            satu foto, dan CatatDigital urus semuanya.
          </p>
        </div>

        <!-- Cards -->
        <div class="feat-grid">
          <!-- Card 1: Auto Scan -->
          <div class="feat-card fade-up">
            <div class="feat-glow em"></div>
            <div class="feat-icon-wrap em">
              <svg
                width="24"
                height="24"
                fill="none"
                viewBox="0 0 24 24"
                stroke="var(--em-400)"
                stroke-width="2"
              >
                <path
